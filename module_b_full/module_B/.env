# Скопируйте этот файл в .env и заполните значения.
# Module B использует ту же БД, что и Module A.

GEMINI_API_KEY=your_gemini_api_key_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=educational_materials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# Или используйте единую строку подключения:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/educational_materials

# Пароли для входа в дашборд (опционально, по умолчанию заданы в config.py)
# DASHBOARD_ADMIN_PASS=admin123
# DASHBOARD_TEACHER_PASS=teacher123
# DASHBOARD_STUDENT_PASS=student123
